<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rifqy Ridho Pratama - 3D Interactive Portfolio</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-dark: #0a0a14;
            --secondary-dark: #1a1a2e;
            --accent-primary: #a855f7;
            --accent-light: #d946ef;
            --text-primary: #e0e0e0;
            --text-secondary: #b0b0b0;
            --border-color: rgba(168, 85, 247, 0.2);
            --glow-color: rgba(168, 85, 247, 0.5);
            --success-color: #10b981;
        }

        html {
            scroll-behavior: smooth;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, var(--primary-dark) 0%, #1a0033 50%, var(--primary-dark) 100%);
            color: var(--text-primary);
            overflow-x: hidden;
            position: relative;
            background-attachment: fixed;
        }

        /* ===== CUSTOM CURSOR ===== */
        .cursor-glow {
            position: fixed;
            width: 40px;
            height: 40px;
            border: 2px solid var(--accent-primary);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            box-shadow: 0 0 20px var(--glow-color), inset 0 0 20px rgba(168, 85, 247, 0.3);
            display: none;
            transition: all 0.1s ease;
        }

        @media (min-width: 1024px) {
            .cursor-glow {
                display: block;
            }
        }

        /* ===== LOADING SCREEN ===== */
        .loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, var(--primary-dark) 0%, #1a0033 50%, var(--primary-dark) 100%);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10000;
            animation: fadeOut 0.5s ease-in-out 3s forwards;
        }

        .loader {
            width: 80px;
            height: 80px;
            border: 4px solid rgba(168, 85, 247, 0.2);
            border-top: 4px solid var(--accent-primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        @keyframes fadeOut {
            to { opacity: 0; visibility: hidden; }
        }

        /* ===== NAVIGATION ===== */
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(10, 10, 20, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border-color);
            z-index: 1000;
            padding: 1rem 0;
            transition: all 0.3s ease;
        }

        .nav-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-logo {
            font-size: 24px;
            font-weight: 800;
            background: linear-gradient(135deg, #fff 0%, var(--accent-primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            display: flex;
            align-items: center;
            gap: 8px;
            letter-spacing: 2px;
        }

        .logo-dot {
            width: 10px;
            height: 10px;
            background: var(--accent-light);
            border-radius: 50%;
            animation: pulse-dot 2s ease-in-out infinite;
        }

        @keyframes pulse-dot {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.2); opacity: 0.7; }
        }

        .nav-menu {
            display: flex;
            list-style: none;
            gap: 3rem;
        }

        .nav-link {
            color: var(--text-primary);
            text-decoration: none;
            font-weight: 500;
            position: relative;
            transition: all 0.3s ease;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .nav-link::after {
            content: '';
            position: absolute;
            bottom: -8px;
            left: 0;
            width: 0;
            height: 2px;
            background: linear-gradient(90deg, var(--accent-primary), var(--accent-light));
            transition: width 0.3s ease;
            box-shadow: 0 0 10px var(--glow-color);
        }

        .nav-link:hover {
            color: var(--accent-light);
            transform: translateY(-2px);
        }

        .nav-link:hover::after {
            width: 100%;
        }

        .hamburger {
            display: none;
            flex-direction: column;
            cursor: pointer;
            gap: 6px;
        }

        .hamburger span {
            width: 25px;
            height: 3px;
            background: var(--accent-primary);
            border-radius: 2px;
            transition: all 0.3s ease;
        }

        @media (max-width: 768px) {
            .nav-menu {
                display: none;
                position: absolute;
                top: 100%;
                left: 0;
                width: 100%;
                flex-direction: column;
                background: rgba(10, 10, 20, 0.95);
                backdrop-filter: blur(10px);
                padding: 2rem;
                gap: 1.5rem;
                border-bottom: 1px solid var(--border-color);
            }

            .nav-menu.active {
                display: flex;
            }

            .hamburger {
                display: flex;
            }
        }

        /* ===== HERO SECTION ===== */
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            margin-top: 60px;
            position: relative;
            overflow: hidden;
        }

        .hero::before {
            content: '';
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(168, 85, 247, 0.15) 0%, transparent 70%);
            border-radius: 50%;
            top: 10%;
            left: 5%;
            animation: float-blob 8s ease-in-out infinite;
            filter: blur(50px);
        }

        .hero::after {
            content: '';
            position: absolute;
            width: 350px;
            height: 350px;
            background: radial-gradient(circle, rgba(217, 70, 239, 0.1) 0%, transparent 70%);
            border-radius: 50%;
            bottom: 5%;
            right: 5%;
            animation: float-blob 10s ease-in-out infinite reverse;
            filter: blur(50px);
        }

        @keyframes float-blob {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-30px); }
        }

        .hero-content {
            max-width: 1400px;
            width: 100%;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: center;
            position: relative;
            z-index: 1;
        }

        .hero-text {
            animation: slideInLeft 1s ease-out;
        }

        @keyframes slideInLeft {
            from {
                opacity: 0;
                transform: translateX(-50px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .hero-title {
            font-size: clamp(48px, 8vw, 80px);
            font-weight: 800;
            line-height: 1.2;
            margin-bottom: 1rem;
            background: linear-gradient(135deg, #fff 0%, var(--accent-primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .highlight {
            color: var(--accent-light);
            text-shadow: 0 0 30px rgba(217, 70, 239, 0.5);
            animation: pulse-text 2s ease-in-out infinite;
        }

        @keyframes pulse-text {
            0%, 100% { text-shadow: 0 0 30px rgba(217, 70, 239, 0.5); }
            50% { text-shadow: 0 0 60px rgba(217, 70, 239, 0.8); }
        }

        .hero-subtitle {
            font-size: clamp(18px, 3vw, 32px);
            font-weight: 300;
            color: var(--accent-primary);
            margin-bottom: 1.5rem;
            text-shadow: 0 0 20px var(--glow-color);
        }

        .hero-description {
            font-size: 16px;
            line-height: 1.8;
            margin-bottom: 2rem;
            color: var(--text-secondary);
            max-width: 500px;
        }

        .hero-buttons {
            display: flex;
            gap: 1.5rem;
            flex-wrap: wrap;
        }

        .btn {
            padding: 14px 32px;
            border: 2px solid var(--accent-primary);
            background: transparent;
            color: var(--text-primary);
            border-radius: 50px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            position: relative;
            overflow: hidden;
            font-family: 'Poppins', sans-serif;
            text-transform: uppercase;
            letter-spacing: 1px;
            text-decoration: none;
            display: inline-block;
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: var(--accent-primary);
            z-index: -1;
            transition: left 0.3s ease;
        }

        .btn-primary:hover {
            color: var(--primary-dark);
            box-shadow: 0 0 30px var(--glow-color);
            transform: translateY(-3px);
        }

        .btn-primary:hover::before {
            left: 0;
        }

        .btn-secondary {
            border-color: rgba(168, 85, 247, 0.5);
            color: var(--accent-primary);
        }

        .btn-secondary::before {
            background: rgba(168, 85, 247, 0.2);
        }

        .btn-secondary:hover {
            border-color: var(--accent-light);
            color: var(--primary-dark);
            box-shadow: 0 0 20px var(--glow-color);
        }

        .btn-secondary:hover::before {
            left: 0;
        }

        /* ===== 3D CANVAS ===== */
        .hero-3d {
            position: relative;
            height: 500px;
            display: flex;
            align-items: center;
            justify-content: center;
            animation: slideInRight 1s ease-out;
        }

        @keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(50px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        #canvas3d {
            width: 100%;
            height: 100%;
        }

        .glow-ring {
            position: absolute;
            inset: 0;
            border: 2px solid rgba(168, 85, 247, 0.3);
            border-radius: 50%;
            animation: pulse-ring 2s ease-in-out infinite;
            pointer-events: none;
        }

        @keyframes pulse-ring {
            0%, 100% { transform: scale(1); opacity: 0.3; }
            50% { transform: scale(1.1); opacity: 0.1; }
        }

        @media (max-width: 968px) {
            .hero-content {
                grid-template-columns: 1fr;
            }

            .hero-3d {
                height: 350px;
                order: -1;
            }

            .hero-buttons {
                flex-direction: column;
            }

            .btn {
                width: 100%;
                text-align: center;
            }
        }

        /* ===== SECTION STYLES ===== */
        .section {
            padding: 6rem 2rem;
            position: relative;
            overflow: hidden;
        }

        .section:nth-child(even) {
            background: linear-gradient(180deg, rgba(168, 85, 247, 0.05) 0%, transparent 100%);
        }

        .section-container {
            max-width: 1400px;
            margin: 0 auto;
            position: relative;
            z-index: 1;
        }

        .section-title {
            font-size: clamp(36px, 5vw, 56px);
            font-weight: 800;
            margin-bottom: 3rem;
            text-align: center;
            background: linear-gradient(135deg, #fff 0%, var(--accent-primary) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            position: relative;
        }

        .section-title::after {
            content: '';
            position: absolute;
            bottom: -15px;
            left: 50%;
            transform: translateX(-50%);
            width: 120px;
            height: 4px;
            background: linear-gradient(90deg, var(--accent-primary), var(--accent-light));
            border-radius: 2px;
            box-shadow: 0 0 20px var(--glow-color);
        }

        /* ===== PROFILE SECTION ===== */
        .profile {
            background: linear-gradient(180deg, transparent 0%, rgba(168, 85, 247, 0.03) 100%);
        }

        .profile-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: start;
        }

        .profile-card {
            background: rgba(26, 26, 46, 0.4);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 2.5rem;
            transition: all 0.3s ease;
            animation: fadeInUp 0.6s ease-out 0.2s both;
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .profile-card:hover {
            border-color: var(--accent-primary);
            box-shadow: 0 0 40px rgba(168, 85, 247, 0.2);
            transform: translateY(-10px);
        }

        .profile-header {
            display: flex;
            gap: 2rem;
            margin-bottom: 2rem;
        }

        .avatar {
            width: 120px;
            height: 120px;
            background: linear-gradient(135deg, var(--accent-primary), var(--accent-light));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 48px;
            font-weight: 800;
            box-shadow: 0 0 40px var(--glow-color);
            flex-shrink: 0;
        }

        .profile-info h3 {
            font-size: 28px;
            margin-bottom: 0.5rem;
        }

        .profile-status {
            color: var(--accent-primary);
            font-weight: 600;
            margin-bottom: 0.5rem;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .profile-location {
            color: var(--text-secondary);
            font-size: 14px;
        }

        .profile-description {
            line-height: 1.8;
            color: var(--text-secondary);
            margin-top: 1.5rem;
        }

        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 2rem;
            margin-top: 2rem;
        }

        .skill-card {
            background: rgba(26, 26, 46, 0.4);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            border-radius: 15px;
            padding: 1.5rem;
            transition: all 0.3s ease;
            animation: fadeInUp 0.6s ease-out 0.3s both;
        }

        .skill-card:hover {
            border-color: var(--accent-primary);
            box-shadow: 0 0 30px rgba(168, 85, 247, 0.15);
            transform: translateY(-5px);
        }

        .skill-header {
            display: flex;
            justify-content: space-between;
            margin-bottom: 1rem;
        }

        .skill-name {
            font-weight: 600;
            font-size: 16px;
        }

        .skill-percent {
            color: var(--accent-primary);
            font-weight: 700;
            font-size: 14px;
        }

        .skill-bar {
            width: 100%;
            height: 8px;
            background: rgba(168, 85, 247, 0.1);
            border-radius: 4px;
            overflow: hidden;
        }

        .skill-progress {
            height: 100%;
            background: linear-gradient(90deg, var(--accent-primary), var(--accent-light));
            border-radius: 4px;
            box-shadow: 0 0 15px var(--glow-color);
            transition: width 1.5s cubic-bezier(0.34, 1.56, 0.64, 1);
            width: 0;
        }

        @media (max-width: 968px) {
            .profile-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ===== RESUME SECTION ===== */
        .resume-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
        }

        .timeline-group {
            background: rgba(26, 26, 46, 0.4);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 2.5rem;
            animation: fadeInUp 0.6s ease-out 0.2s both;
        }

        .timeline-title {
            font-size: 24px;
            font-weight: 700;
            margin-bottom: 2rem;
            color: var(--accent-primary);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .timeline {
            position: relative;
            padding-left: 30px;
        }

        .timeline::before {
            content: '';
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 2px;
            background: linear-gradient(180deg, var(--accent-primary), transparent);
        }

        .timeline-item {
            position: relative;
            margin-bottom: 2.5rem;
            padding-bottom: 2.5rem;
            animation: fadeInUp 0.6s ease-out;
        }

        .timeline-item:last-child {
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .timeline-marker {
            position: absolute;
            left: -36px;
            top: 0;
            width: 14px;
            height: 14px;
            background: var(--accent-primary);
            border: 3px solid var(--secondary-dark);
            border-radius: 50%;
            box-shadow: 0 0 20px var(--glow-color);
            transition: all 0.3s ease;
        }

        .timeline-item:hover .timeline-marker {
            width: 22px;
            height: 22px;
            left: -39px;
            box-shadow: 0 0 30px var(--glow-color);
            transform: scale(1.2);
        }

        .timeline-content h4 {
            font-size: 18px;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .timeline-meta {
            color: var(--accent-primary);
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 0.5rem;
        }

        .timeline-description {
            color: var(--text-secondary);
            font-size: 14px;
            line-height: 1.6;
        }

        @media (max-width: 968px) {
            .resume-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ===== PROJECTS SECTION ===== */
        .projects-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 2.5rem;
        }

        .project-card {
            background: rgba(26, 26, 46, 0.4);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            overflow: hidden;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            transform-style: preserve-3d;
            animation: fadeInUp 0.6s ease-out;
            cursor: pointer;
        }

        .project-card:hover {
            border-color: var(--accent-primary);
            box-shadow: 0 0 40px rgba(168, 85, 247, 0.3);
            transform: translateY(-15px) rotateX(5deg);
        }

        .project-image {
            width: 100%;
            height: 250px;
            background: linear-gradient(135deg, rgba(168, 85, 247, 0.1), rgba(217, 70, 239, 0.1));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 100px;
            position: relative;
            overflow: hidden;
        }

        .project-image::before {
            content: '';
            position: absolute;
            width: 100%;
            height: 100%;
            background: linear-gradient(45deg, transparent 30%, rgba(168, 85, 247, 0.1) 50%, transparent 70%);
            animation: shimmer 3s infinite;
        }

        @keyframes shimmer {
            0% { transform: translateX(-100%); }
            100% { transform: translateX(100%); }
        }

        .project-emoji {
            z-index: 1;
            filter: drop-shadow(0 0 20px var(--glow-color));
            transition: transform 0.3s ease;
        }

        .project-card:hover .project-emoji {
            transform: scale(1.2) rotate(10deg);
        }

        .project-content {
            padding: 2rem;
        }

        .project-content h3 {
            font-size: 22px;
            margin-bottom: 0.5rem;
            color: var(--text-primary);
        }

        .project-tech {
            color: var(--accent-primary);
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 1rem;
            display: flex;
            flex-wrap: wrap;
            gap: 0.5rem;
        }

        .project-tech span {
            background: rgba(168, 85, 247, 0.1);
            padding: 4px 12px;
            border-radius: 20px;
            border: 1px solid var(--border-color);
        }

        .project-description {
            color: var(--text-secondary);
            font-size: 14px;
            line-height: 1.6;
            margin-bottom: 1.5rem;
        }

        .project-links {
            display: flex;
            gap: 1rem;
        }

        .project-link {
            flex: 1;
            padding: 10px 16px;
            background: rgba(168, 85, 247, 0.15);
            color: var(--accent-primary);
            border: 1px solid var(--accent-primary);
            border-radius: 8px;
            text-decoration: none;
            text-align: center;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            transition: all 0.3s ease;
            cursor: pointer;
        }

        .project-link:hover {
            background: var(--accent-primary);
            color: var(--primary-dark);
            box-shadow: 0 0 20px var(--glow-color);
            transform: translateY(-2px);
        }

        /* ===== CONTACT SECTION ===== */
        .contact-wrapper {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
            align-items: start;
        }

        .contact-form-box {
            background: rgba(26, 26, 46, 0.4);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-color);
            border-radius: 20px;
            padding: 2.5rem;
            animation: fadeInUp 0.6s ease-out 0.2s both;
        }

        .contact-form {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .form-group label {
            color: var(--accent-primary);
            font-weight: 600;
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .form-group input,
        .form-group textarea {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--border-color);
            border-radius: 10px;
            padding: 12px 16px;
            color: var(--text-primary);
            font-family: 'Poppins', sans-serif;
            font-size: 14px;
            transition: all 0.3s ease;
        }

        .form-group input::placeholder,
        .form-group textarea::placeholder {
            color: rgba(224, 224, 224, 0.3);
        }

        .form-group input:focus,
        .form-group textarea:focus {
            outline: none;
            border-color: var(--accent-primary);
            background: rgba(168, 85, 247, 0.1);
            box-shadow: 0 0 20px rgba(168, 85, 247, 0.2);
        }

        .form-group textarea {
            resize: vertical;
            min-height: 120px;
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
