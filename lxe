    <!-- MAIN SCRIPT -->
    <script>
        // ===== VARIABLES =====
        const cursorGlow = document.querySelector('.cursor-glow');
        const hamburger = document.querySelector('.hamburger');
        const navMenu = document.querySelector('.nav-menu');
        const navLinks = document.querySelectorAll('.nav-link');
        const contactForm = document.getElementById('contactForm');

        // ===== CUSTOM CURSOR =====
        document.addEventListener('mousemove', (e) => {
            if (cursorGlow) {
                cursorGlow.style.left = (e.clientX - 20) + 'px';
                cursorGlow.style.top = (e.clientY - 20) + 'px';
            }
        });

        // ===== LOADING SCREEN =====
        window.addEventListener('load', () => {
            const loadingScreen = document.querySelector('.loading-screen');
            setTimeout(() => {
                loadingScreen.style.opacity = '0';
                loadingScreen.style.pointerEvents = 'none';
            }, 3000);
        });

        // ===== MOBILE MENU =====
        hamburger.addEventListener('click', () => {
            navMenu.classList.toggle('active');
        });

        navLinks.forEach(link => {
            link.addEventListener('click', () => {
                navMenu.classList.remove('active');
            });
        });

        // ===== SMOOTH SCROLL & ACTIVE NAV =====
        window.addEventListener('scroll', () => {
            const sections = document.querySelectorAll('section[id]');
            const scrollPosition = window.scrollY + 100;

            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.offsetHeight;

                navLinks.forEach(link => {
                    link.style.color = 'var(--text-primary)';
                    if (link.getAttribute('href') === `#${section.id}` && 
                        scrollPosition >= sectionTop && 
                        scrollPosition < sectionTop + sectionHeight) {
                        link.style.color = 'var(--accent-light)';
                        link.style.textShadow = '0 0 10px var(--glow-color)';
                    }
                });
            });
        });

        // ===== 3D ROBOT WITH THREE.JS =====
        let mouseX = 0;
        let mouseY = 0;
        let targetX = 0;
        let targetY = 0;

        document.addEventListener('mousemove', (e) => {
            targetX = (e.clientX / window.innerWidth) * 2 - 1;
            targetY = -(e.clientY / window.innerHeight) * 2 + 1;
        });

        document.addEventListener('touchmove', (e) => {
            if (e.touches.length > 0) {
                targetX = (e.touches[0].clientX / window.innerWidth) * 2 - 1;
                targetY = -(e.touches[0].clientY / window.innerHeight) * 2 + 1;
            }
        });

        // Three.js Scene Setup
        const canvas = document.getElementById('canvas3d');
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, canvas.clientWidth / canvas.clientHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });

        renderer.setSize(canvas.clientWidth, canvas.clientHeight);
        renderer.setClearColor(0x000000, 0);
        camera.position.z = 5;

        // Create 3D Robot
        const robotGroup = new THREE.Group();
        scene.add(robotGroup);

        // Robot Body - Main cylinder
        const bodyGeometry = new THREE.CylinderGeometry(0.8, 0.8, 2, 32);
        const bodyMaterial = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness: 0.4, metalness: 0.3 });
        const body = new THREE.Mesh(bodyGeometry, bodyMaterial);
        body.position.y = -0.5;
        robotGroup.add(body);

        // Robot Head
        const headGeometry = new THREE.SphereGeometry(0.6, 32, 32);
        const headMaterial = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness: 0.4, metalness: 0.3 });
        const head = new THREE.Mesh(headGeometry, headMaterial);
        head.position.y = 1.8;
        robotGroup.add(head);

        // Left Eye
        const eyeGeometry = new THREE.SphereGeometry(0.15, 16, 16);
        const eyeMaterial = new THREE.MeshStandardMaterial({ color: 0xa855f7 });
        const leftEye = new THREE.Mesh(eyeGeometry, eyeMaterial);
        leftEye.position.set(-0.2, 2.0, 0.55);
        robotGroup.add(leftEye);

        // Right Eye
        const rightEye = leftEye.clone();
        rightEye.position.x = 0.2;
        robotGroup.add(rightEye);

        // Left Arm
        const armGeometry = new THREE.BoxGeometry(0.3, 1.5, 0.3);
        const armMaterial = new THREE.MeshStandardMaterial({ color: 0xffffff, roughness: 0.4, metalness: 0.3 });
        const leftArm = new THREE.Mesh(armGeometry, armMaterial);
        leftArm.position.set(-1.2, 0.5, 0);
        robotGroup.add(leftArm);

        // Right Arm
        const rightArm = leftArm.clone();
        rightArm.position.x = 1.2;
        robotGroup.add(rightArm);

        // Left Leg
        const legGeometry = new THREE.BoxGeometry(0.3, 1.2, 0.3);
        const legMaterial = new THREE.MeshStandardMaterial({ color: 0xa855f7, roughness: 0.4, metalness: 0.3 });
        const leftLeg = new THREE.Mesh(legGeometry, legMaterial);
        leftLeg.position.set(-0.4, -1.8, 0);
        robotGroup.add(leftLeg);

        // Right Leg
        const rightLeg = leftLeg.clone();
        rightLeg.position.x = 0.4;
        robotGroup.add(rightLeg);

        // Lighting
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.6);
        scene.add(ambientLight);

        const pointLight = new THREE.PointLight(0xa855f7, 1, 100);
        pointLight.position.set(5, 5, 5);
        scene.add(pointLight);

        const pointLight2 = new THREE.PointLight(0xd946ef, 1, 100);
        pointLight2.position.set(-5, -5, 5);
        scene.add(pointLight2);

        // Animation Loop
        function animate() {
            requestAnimationFrame(animate);

            // Smooth mouse tracking
            mouseX += (targetX - mouseX) * 0.08;
            mouseY += (targetY - mouseY) * 0.08;

            // Robot rotation based on cursor
            robotGroup.rotation.y = mouseX * 0.5;
            robotGroup.rotation.x = mouseY * 0.3;

            // Arm animation
            const time = Date.now() * 0.001;
            leftArm.rotation.z = Math.sin(time) * 0.3;
            rightArm.rotation.z = -Math.sin(time) * 0.3;

            // Leg animation
            leftLeg.rotation.x = Math.sin(time * 1.5) * 0.15;
            rightLeg.rotation.x = -Math.sin(time * 1.5) * 0.15;

            // Eyes glow pulse
            leftEye.material.emissive.setHex(0xa855f7);
            rightEye.material.emissive.setHex(0xa855f7);
            leftEye.material.emissiveIntensity = 0.5 + Math.sin(time * 2) * 0.3;
            rightEye.material.emissiveIntensity = 0.5 + Math.sin(time * 2) * 0.3;

            renderer.render(scene, camera);
        }
        animate();

        // Handle window resize
        window.addEventListener('resize', () => {
            const width = canvas.clientWidth;
            const height = canvas.clientHeight;
            camera.aspect = width / height;
            camera.updateProjectionMatrix();
            renderer.setSize(width, height);
        });

        // ===== SKILL PROGRESS ANIMATION =====
        function animateSkillBars() {
            const skillCards = document.querySelectorAll('.skill-card');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        const progressBars = entry.target.querySelectorAll('.skill-progress');
                        progressBars.forEach(bar => {
                            const targetWidth = bar.getAttribute('data-width');
                            setTimeout(() => {
                                bar.style.width = targetWidth + '%';
                            }, 100);
                        });
                        observer.unobserve(entry.target);
                    }
                });
            });

            skillCards.forEach(card => observer.observe(card));
        }
        animateSkillBars();

        // ===== SCROLL ANIMATIONS =====
        function initScrollAnimations() {
            const elements = document.querySelectorAll('.profile-card, .skill-card, .project-card, .timeline-item, .contact-item, .timeline-group, .contact-form-box');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            }, {
                threshold: 0.1,
                rootMargin: '0px 0px -50px 0px'
            });

            elements.forEach(el => {
                el.style.opacity = '0';
                el.style.transform = 'translateY(30px)';
                el.style.transition = 'all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1)';
                observer.observe(el);
            });
        }
        initScrollAnimations();

        // ===== CONTACT FORM SUBMISSION =====
        contactForm.addEventListener('submit', (e) => {
            e.preventDefault();

            const name = document.getElementById('name').value;
            const email = document.getElementById('email').value;
            const message = document.getElementById('message').value;

            if (!name || !email || !message) {
                alert('Mohon isi semua kolom');
                return;
            }

            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(email)) {
                alert('Email tidak valid');
                return;
            }

            const mailtoLink = `mailto:rifqyridhopratama29@gmail.com?subject=Pesan dari ${encodeURIComponent(name)}&body=${encodeURIComponent(message)}\n\nDari: ${encodeURIComponent(email)}`;
            window.location.href = mailtoLink;

            contactForm.reset();
        });

        // ===== CONSOLE MESSAGE =====
        console.log('%c🚀 Welcome to Rifqy Ridho Pratama 3D Portfolio', 'color: #a855f7; font-size: 18px; font-weight: bold;');
        console.log('%cMove your cursor to interact with the robot! 🤖', 'color: #d946ef; font-size: 14px;');
    </script>
</body>
